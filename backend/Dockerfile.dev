# Start from the same base image as the production build for consistency
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update \
 && apt-get install -y build-essential \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# Install Poetry
RUN pip install --no-cache-dir "poetry==1.8.3"
ENV POETRY_VIRTUALENVS_CREATE=false

# Copy only the dependency files
COPY pyproject.toml poetry.lock ./

# Regenerate lock file to match pyproject.toml, then install
RUN poetry lock --no-update --no-interaction --no-ansi
RUN poetry install --no-root --no-interaction --no-ansi

COPY . .

# We will mount the application code using a volume,
# so we don't need to COPY code here.
# (The command will be specified in docker-compose.yml)